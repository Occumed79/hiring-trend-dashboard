# ─────────────────────────────────────────────────────────────────
# Neon Postgres (required)
# ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/hiring_dashboard?sslmode=require

# ─────────────────────────────────────────────────────────────────
# App
# ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
CRON_SECRET=replace_with_a_long_random_string

# ─────────────────────────────────────────────────────────────────
# Adzuna API (used by: Current Clients, Prospects, Private Companies,
#             State Agencies, Counties & Cities)
# Register at: https://developer.adzuna.com
# ─────────────────────────────────────────────────────────────────
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key

# ─────────────────────────────────────────────────────────────────
# USAJOBS API (used by: Federal Agencies, State Agencies, Counties & Cities)
# Register at: https://developer.usajobs.gov
# USAJOBS_USER_AGENT should be the email you registered with
# ─────────────────────────────────────────────────────────────────
USAJOBS_API_KEY=your_usajobs_api_key
USAJOBS_USER_AGENT=your_email@example.com

# ─────────────────────────────────────────────────────────────────
# Private Companies Portal — optional
# If missing, the portal falls back to ATS + career page + Adzuna
# ─────────────────────────────────────────────────────────────────
PRIVATE_SECTOR_HIRING_API_KEY=
PRIVATE_SECTOR_HIRING_API_BASE_URL=

# ─────────────────────────────────────────────────────────────────
# Federal Agencies Portal — optional
# If missing, the portal falls back to USAJOBS + career page
# ─────────────────────────────────────────────────────────────────
FEDERAL_HIRING_API_KEY=
FEDERAL_HIRING_API_BASE_URL=

# ─────────────────────────────────────────────────────────────────
# State Agencies Portal — optional
# If missing, the portal falls back to Adzuna + USAJOBS + career page
# ─────────────────────────────────────────────────────────────────
STATE_HIRING_API_KEY=
STATE_HIRING_API_BASE_URL=

# ─────────────────────────────────────────────────────────────────
# Counties & Cities Portal — optional (three independent sources)
# If missing, the portal falls back to Adzuna + USAJOBS + career page
# ─────────────────────────────────────────────────────────────────
COUNTY_HIRING_API_KEY=
COUNTY_HIRING_API_BASE_URL=

CITY_HIRING_API_KEY=
CITY_HIRING_API_BASE_URL=

MUNICIPAL_HIRING_API_KEY=
MUNICIPAL_HIRING_API_BASE_URL=
