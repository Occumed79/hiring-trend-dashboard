# ─────────────────────────────────────────────────────────────────
# Neon Postgres (required)
# ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/hiring_dashboard?sslmode=require

# ─────────────────────────────────────────────────────────────────
# App
# ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
CRON_SECRET=replace_with_a_long_random_string

# ─────────────────────────────────────────────────────────────────
# Adzuna API (used by: Current Clients, Prospects, Private Companies,
#             State Agencies, Counties & Cities)
# Register at: https://developer.adzuna.com
# ─────────────────────────────────────────────────────────────────
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key

# ─────────────────────────────────────────────────────────────────
# USAJOBS API (used by: Federal Agencies, State Agencies, Counties & Cities)
# Register at: https://developer.usajobs.gov
# USAJOBS_USER_AGENT should be the email you registered with
# ─────────────────────────────────────────────────────────────────
USAJOBS_API_KEY=your_usajobs_api_key
USAJOBS_USER_AGENT=your_email@example.com

# ─────────────────────────────────────────────────────────────────
# Private Companies Portal — optional
# If missing, the portal falls back to ATS + career page + Adzuna
# ─────────────────────────────────────────────────────────────────
PRIVATE_SECTOR_HIRING_API_KEY=
PRIVATE_SECTOR_HIRING_API_BASE_URL=

# ─────────────────────────────────────────────────────────────────
# Federal Agencies Portal — optional
# If missing, the portal falls back to USAJOBS + career page
# ─────────────────────────────────────────────────────────────────
FEDERAL_HIRING_API_KEY=
FEDERAL_HIRING_API_BASE_URL=

# ─────────────────────────────────────────────────────────────────
# State Agencies Portal — optional
# If missing, the portal falls back to Adzuna + USAJOBS + career page
# ─────────────────────────────────────────────────────────────────
STATE_HIRING_API_KEY=
STATE_HIRING_API_BASE_URL=

# ─────────────────────────────────────────────────────────────────
# Counties & Cities Portal — optional (three independent sources)
# If missing, the portal falls back to Adzuna + USAJOBS + career page
# ─────────────────────────────────────────────────────────────────
COUNTY_HIRING_API_KEY=
COUNTY_HIRING_API_BASE_URL=

CITY_HIRING_API_KEY=
CITY_HIRING_API_BASE_URL=

MUNICIPAL_HIRING_API_KEY=
MUNICIPAL_HIRING_API_BASE_URL=

# ─────────────────────────────────────────────────────────────────
# RapidAPI Job Search APIs
# ─────────────────────────────────────────────────────────────────
RAPID_API_KEY=af8aede4cbmshf3ddaadbab738b7p1c7e44jsn4388347ffd70

# JSearch (Mega) API
JOB_API_JSEARCH_HOST=jsearch.p.rapidapi.com
JOB_API_JSEARCH_PATH=/search

# Indeed Realtime Job Search API
JOB_API_INDEED_HOST=indeed-realtime-job-search-api.p.rapidapi.com
JOB_API_INDEED_PATH=/search

# LinkedIn Jobs API
JOB_API_LINKEDIN_HOST=linkedin-jobs-search.p.rapidapi.com
JOB_API_LINKEDIN_PATH=/search

# Google Jobs API
JOB_API_GOOGLE_JOBS_HOST=google-jobs-search.p.rapidapi.com
JOB_API_GOOGLE_JOBS_PATH=/search

# ZipRecruiter API
JOB_API_ZIPRECRUITER_HOST=ziprecruiter-api.p.rapidapi.com
JOB_API_ZIPRECRUITER_PATH=/search

# Glassdoor API
JOB_API_GLASSDOOR_HOST=glassdoor-real-time.p.rapidapi.com
JOB_API_GLASSDOOR_PATH=/search

# JobBank API
JOB_API_JOBBANK_HOST=jobbank-real-time-linkedin-indeed-glassdoor.p.rapidapi.com
JOB_API_JOBBANK_PATH=/search

# JobFinder API
JOB_API_JOBFINDER_HOST=jobfinder.p.rapidapi.com
JOB_API_JOBFINDER_PATH=/search

# Latest Jobs API
JOB_API_LATEST_JOBS_HOST=latest-jobs-api.p.rapidapi.com
JOB_API_LATEST_JOBS_PATH=/search

# Job Search AI API
JOB_API_JOB_SEARCH_AI_HOST=job-search-ai.p.rapidapi.com
JOB_API_JOB_SEARCH_AI_PATH=/search

# Real Time LinkedIn Job Search API
JOB_API_REALTIME_LINKEDIN_HOST=real-time-linkedin-job-search-api.p.rapidapi.com
JOB_API_REALTIME_LINKEDIN_PATH=/search

# Job Listings Aggregator
JOB_API_JOB_LISTINGS_HOST=job-listings-aggregator.p.rapidapi.com
JOB_API_JOB_LISTINGS_PATH=/search

# Job Search Real Time Data
JOB_API_JOB_SEARCH_REALTIME_HOST=job-search-real-time-data.p.rapidapi.com
JOB_API_JOB_SEARCH_REALTIME_PATH=/search

# Jobs API (general)
JOB_API_JOBS_HOST=jobs-api.p.rapidapi.com
JOB_API_JOBS_PATH=/search

# Job Parser
JOB_API_JOB_PARSER_HOST=job-parser.p.rapidapi.com
JOB_API_JOB_PARSER_PATH=/parse

# Lead Scraper
JOB_API_LEAD_SCRAPER_HOST=lead-scraper.p.rapidapi.com
JOB_API_LEAD_SCRAPER_PATH=/search

# HireBase Jobs Data
JOB_API_HIREBASE_HOST=hirebase-jobs-data.p.rapidapi.com
JOB_API_HIREBASE_PATH=/search

# InternSignal Jobs API
JOB_API_INTERNSIGNAL_HOST=internsignal-jobs-api.p.rapidapi.com
JOB_API_INTERNSIGNAL_PATH=/search

# Free Y Combinator Jobs API
JOB_API_YC_JOBS_HOST=free-y-combinator-jobs-api.p.rapidapi.com
JOB_API_YC_JOBS_PATH=/search

# Job Posting Feed API
JOB_API_JOB_POSTING_FEED_HOST=job-posting-feed-api.p.rapidapi.com
JOB_API_JOB_POSTING_FEED_PATH=/feed

# Active Jobs DB
JOB_API_ACTIVE_JOBS_HOST=active-jobs-db.p.rapidapi.com
JOB_API_ACTIVE_JOBS_PATH=/search

# ─────────────────────────────────────────────────────────────────
# Job API Configuration
# ─────────────────────────────────────────────────────────────────
JOB_API_ADAPTERS=jsearch,indeed,linkedin,google_jobs,ziprecruiter,glassdoor,jobbank,jobfinder,latest_jobs,job_search_ai,realtime_linkedin,job_listings,job_search_realtime,jobs,job_parser,lead_scraper,hirebase,internsignal,yc_jobs,job_posting_feed,active_jobs
JOB_API_COUNTRY=us
JOB_API_LIMIT=25
JOB_API_DATE_POSTED=month
